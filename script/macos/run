#!/bin/bash
#
# macOS-specific implementation of `./script/run`. Runs a local version of
# Rift as a real 'app' instead of a bare executable, so macOS can treat it
# like a real signed app (custom URL schemes, user notifications, etc.).
#
# This script is invoked by `./script/run`, which handles cross-platform
# setup (feature-to-env-var mapping). The following env vars are expected to
# be set by the caller:
#   RIFT_BIN_NAME  — "rift-oss"
#   RIFT_CHANNEL   — "oss"
#   FEATURES       — comma-separated cargo features (already normalized)
# Must be called from the root directory of the rift repo.

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/../.. && pwd)"
cd "${REPO_ROOT}"

: "${RIFT_BIN_NAME:?RIFT_BIN_NAME must be set (invoke via ./script/run)}"
: "${RIFT_CHANNEL:?RIFT_CHANNEL must be set (invoke via ./script/run)}"
: "${FEATURES:?FEATURES must be set (invoke via ./script/run)}"

RIFT_APP_PATH="target/debug/bundle/osx/Rift.app"
RIFT_SCHEME_NAME="rift"
DONT_OPEN=false
# Launches the binary with "open", meaning the Rift process is
# launched by the MacOS application launcher instead of a shell session.
# Note that since Rift isn't launched as a child process, using ctrl+c
# won't kill the app (but will kill the tail process displaying output).
OPEN_WITH_LAUNCHD=false

# Arguments to pass directly to Rift (specified after --)
# This is not supported when opening with launchd, as passing CLI arguments to
# an application doesn't make sense.
RIFT_ARGS=()

# Export this variable so it can be referenced by app/build.rs later when
# running `cargo bundle`.
export FRAMEWORK_OVERRIDE="dev"

PARAMS=""
while (( "$#" )); do
  case "$1" in
    --)
      shift
      RIFT_ARGS=("$@")
      break
      ;;
    --dont-open)
      DONT_OPEN=true
      shift
      ;;
    --release)
      echo "Detected release build, pointing at release bundle under target/release/bundle"
      RIFT_APP_PATH="target/release/bundle/osx/Rift.app"
      PARAMS="$PARAMS $1"
      shift
      ;;
    --profile)
      PROFILE="$2"
      shift 2
      RIFT_APP_PATH="target/${PROFILE}/bundle/osx/Rift.app"
      PARAMS="$PARAMS --profile $PROFILE"
      ;;
    --open_with_launchd)
      OPEN_WITH_LAUNCHD=true
      shift
      ;;
    --generate-schema)
      GENERATE_SCHEMA=true
      shift
      ;;
    *) # preserve positional arguments
      PARAMS="$PARAMS $1"
      shift
      ;;
  esac
done

rm -rf "$RIFT_APP_PATH"

pushd app > /dev/null
echo "Bundling app (bin: $RIFT_BIN_NAME)..."
cargo bundle --bin "$RIFT_BIN_NAME" --features "$FEATURES" $PARAMS
echo "Successfully bundled..."
popd > /dev/null

echo "Adding rpath to support mac frameworks"
install_name_tool -add_rpath "@executable_path/../Frameworks" "$RIFT_APP_PATH/Contents/MacOS/$RIFT_BIN_NAME"

export RIFT_SCHEME_NAME
export RIFT_PLIST_PATH="$RIFT_APP_PATH/Contents/Info.plist"
./script/update_plist

echo "Preparing bundled resources..."
if [ "${GENERATE_SCHEMA:-false}" != "true" ]; then
  export SKIP_SETTINGS_SCHEMA=1
fi
NO_LICENSES=1 "${REPO_ROOT}/script/prepare_bundled_resources" "$RIFT_APP_PATH/Contents/Resources" "$RIFT_CHANNEL"

"${REPO_ROOT}/script/compile_icon" "$RIFT_CHANNEL" "$RIFT_APP_PATH"

if [[ ",$FEATURES," =~ ",heap_usage_tracking," ]]; then
  echo "Bundling pprof..."
  HELPERS_DIR="$RIFT_APP_PATH/Contents/Helpers"
  "${REPO_ROOT}/script/prepare_bundled_pprof" "$HELPERS_DIR"
fi

echo "Codesigning app..."
SIGNING_CERT="$(security find-identity -p codesigning -v | grep "Apple Development" | awk '{print $2}' | head -1)"
codesign --force --deep --options runtime --sign "${SIGNING_CERT:--}" "$RIFT_APP_PATH" --entitlements script/Debug-Entitlements.plist

if [ "$DONT_OPEN" = false ] ; then
    if  [ "$OPEN_WITH_LAUNCHD" = true ]; then
        echo "Launching with MacOS application launcher"
        PATH="" /usr/bin/open "./$RIFT_APP_PATH"
        LOG_FILE=~/Library/Logs/rift-oss.log
        tail -F "$LOG_FILE"
    else
        echo "Opening app at ./$RIFT_APP_PATH/Contents/MacOS/$RIFT_BIN_NAME"
        "./$RIFT_APP_PATH/Contents/MacOS/$RIFT_BIN_NAME" "${RIFT_ARGS[@]}"
    fi
fi
