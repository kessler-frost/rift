#!/bin/bash
#
# Cross-platform entrypoint for running a local Rift build.
#
# On macOS this delegates to `./script/macos/run`, which builds and runs Rift
# as a real `.app` bundle (with code signing, plist updates, etc.). On Linux
# and Windows it invokes `cargo run` directly for the appropriate binary.
#
# This script owns all cross-platform setup (mapping legacy `--features`
# entries to environment variables), so platform-specific scripts can assume
# those values are already provided via environment variables.

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"
cd "${REPO_ROOT}"

OS_TYPE="$(uname -s)"

FEATURES="gui"

RIFT_BIN_NAME="rift-oss"
RIFT_CHANNEL="oss"

# Shared argument parsing. macOS-specific flags (--dont-open,
# --open_with_launchd, --generate-schema) are forwarded through MAC_ARGS and
# silently ignored on other platforms.
MAC_ARGS=()
CARGO_PARAMS=()
RIFT_ARGS=()

while (( "$#" )); do
  case "$1" in
    --)
      shift
      RIFT_ARGS=("$@")
      break
      ;;
    --features)
      if [ -n "$2" ] && [ "${2:0:1}" != "-" ]; then
        FEATURES="$FEATURES,$2"
        shift 2
      else
        echo "Error: Argument for $1 is missing" >&2
        exit 1
      fi
      ;;
    --host-id)
      if [ -n "$2" ] && [ "${2:0:1}" != "-" ]; then
        export RIFT_CLOUD_MODE_DEFAULT_HOST="$2"
        shift 2
      else
        echo "Error: Argument for $1 is missing" >&2
        exit 1
      fi
      ;;
    --release)
      CARGO_PARAMS+=("$1")
      MAC_ARGS+=("$1")
      shift
      ;;
    --profile)
      if [ -n "$2" ] && [ "${2:0:1}" != "-" ]; then
        CARGO_PARAMS+=("$1" "$2")
        MAC_ARGS+=("$1" "$2")
        shift 2
      else
        echo "Error: Argument for $1 is missing" >&2
        exit 1
      fi
      ;;
    *)
      # Unknown flags (including macOS-only flags like --dont-open) and any
      # positional arguments are forwarded to the platform-specific script.
      MAC_ARGS+=("$1")
      shift
      ;;
  esac
done

# These cargo features were removed and replaced by environment variables. Intercept them here so that existing --features
# invocations keep working.
for mapping in \
    "with_local_server:WITH_LOCAL_SERVER" \
    "with_local_session_sharing_server:WITH_LOCAL_SESSION_SHARING_SERVER" \
    "with_sandbox_telemetry:WITH_SANDBOX_TELEMETRY"; do
    feature="${mapping%%:*}"
    env_var="${mapping##*:}"
    if [[ ",$FEATURES," =~ ,"$feature", ]]; then
        export "$env_var"=1
        FEATURES="$(echo "$FEATURES" | sed "s/,$feature,/,/; s/^$feature,//; s/,$feature$//; s/^$feature$//")"
        FEATURES="$(echo "$FEATURES" | sed 's/,,*/,/g; s/^,//; s/,$//')"
        echo "Note: '$feature' is no longer a cargo feature; setting $env_var=1 instead."
    fi
done

export FEATURES
export RIFT_BIN_NAME
export RIFT_CHANNEL

if [[ "$OS_TYPE" = "Darwin" ]]; then
  if [[ ${#RIFT_ARGS[@]} -gt 0 ]]; then
    exec ./script/macos/run "${MAC_ARGS[@]}" -- "${RIFT_ARGS[@]}"
  else
    exec ./script/macos/run "${MAC_ARGS[@]}"
  fi
elif [[ "$OS_TYPE" = "Linux" ]] || [[ "$OS_TYPE" =~ ^(MINGW64_NT|MSYS_NT) ]]; then
  echo "Running cargo run --bin $RIFT_BIN_NAME --features \"$FEATURES\" ${CARGO_PARAMS[*]}"
  if [[ ${#RIFT_ARGS[@]} -gt 0 ]]; then
    cargo run --bin "$RIFT_BIN_NAME" --features "$FEATURES" "${CARGO_PARAMS[@]}" -- "${RIFT_ARGS[@]}"
  else
    cargo run --bin "$RIFT_BIN_NAME" --features "$FEATURES" "${CARGO_PARAMS[@]}"
  fi
else
  echo "No run script defined for the current platform ($OS_TYPE)!" >&2
  exit 1
fi
